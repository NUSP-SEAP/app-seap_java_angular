# ══ Incluir SOMENTE backend/ e frontend/ ══
/*
!backend/
!frontend/
!docker/
!.github/
!.claude/
!.dockerignore
!.gitignore

# ══ Credenciais (NUNCA commitar) ══
docker/.env

# ══ Metabase (banco interno H2 com dashboards/usuários — local por ambiente) ══
docker/metabase-data/

# ══ Backend (Java/Maven) ══
backend/target/
backend/*.jar
backend/*.war
backend/.mvn/
backend/mvnw
backend/mvnw.cmd
backend/.settings/
backend/.project
backend/.classpath
backend/.factorypath
backend/bin/
backend/*.iml
backend/.idea/

# ══ Frontend (Angular/Node) ══
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/.vscode/
frontend/*.tgz
frontend/.env
frontend/.env.*

# ══ Geral ══
*.log
*.swp
*.swo
*.bak
*~
.DS_Store
Thumbs.db
